# Shell scripts and systemd units run on Linux — keep them LF even on Windows
# checkouts (a CRLF .sh fails with "bad interpreter" / sed-isms on the VM).
*.sh text eol=lf
*.service text eol=lf

# GDScript and Godot text resources: normalize to LF for clean cross-platform diffs.
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.cfg text eol=lf
*.godot text eol=lf
*.md text eol=lf
*.svg text eol=lf

# Binary
*.png binary
*.apk binary
